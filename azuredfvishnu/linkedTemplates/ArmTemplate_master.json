{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "azuredfvishnu"
		},
		"Azure_SQL_Linked_Service_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'Azure_SQL_Linked_Service'"
		},
		"df_linked_service_to_datlake_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'df_linked_service_to_datlake'"
		},
		"Azure_SQL_Linked_Service_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "adfprojectreddy.database.windows.net"
		},
		"Azure_SQL_Linked_Service_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "adf_vishnu"
		},
		"Azure_SQL_Linked_Service_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "adminvishnu"
		},
		"df_linked_service_to_datlake_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://datalakevishnureddy.dfs.core.windows.net/"
		},
		"ls_github_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "azuredfvishnu_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"Azure_SQL_Linked_Service_password": {
						"value": "[parameters('Azure_SQL_Linked_Service_password')]"
					},
					"df_linked_service_to_datlake_accountKey": {
						"value": "[parameters('df_linked_service_to_datlake_accountKey')]"
					},
					"Azure_SQL_Linked_Service_properties_typeProperties_server": {
						"value": "[parameters('Azure_SQL_Linked_Service_properties_typeProperties_server')]"
					},
					"Azure_SQL_Linked_Service_properties_typeProperties_database": {
						"value": "[parameters('Azure_SQL_Linked_Service_properties_typeProperties_database')]"
					},
					"Azure_SQL_Linked_Service_properties_typeProperties_userName": {
						"value": "[parameters('Azure_SQL_Linked_Service_properties_typeProperties_userName')]"
					},
					"df_linked_service_to_datlake_properties_typeProperties_url": {
						"value": "[parameters('df_linked_service_to_datlake_properties_typeProperties_url')]"
					},
					"ls_github_properties_typeProperties_url": {
						"value": "[parameters('ls_github_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "azuredfvishnu_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'azuredfvishnu_ArmTemplate_0')]"
			]
		}
	]
}